{
    "name": "romanalisoy/pashabank-laravel-sdk",
    "description": "Laravel 12/13 SDK for PASHA Bank CardSuite ECOMM (3D-Secure acquiring) integration.",
    "version": "1.0.2",
    "keywords": [
        "laravel",
        "pashabank",
        "payment",
        "acquiring",
        "3d-secure",
        "ecomm",
        "cardsuite",
        "azerbaijan"
    ],
    "homepage": "https://github.com/romanalisoy/pashabank-laravel-sdk",
    "license": "MIT",
    "authors": [
        {
            "name": "romanalisoy",
            "email": "mrromanalisoy@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.1",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Romanalisoy\\PashaBank\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Romanalisoy\\PashaBank\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php -d extension=pdo_sqlite -d extension=sqlite3 vendor/bin/pest",
        "test:coverage": "@php -d extension=pdo_sqlite -d extension=sqlite3 vendor/bin/pest --coverage",
        "analyse": "phpstan analyse --memory-limit=1G",
        "format": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Romanalisoy\\PashaBank\\PashaBankServiceProvider"
            ],
            "aliases": {
                "PashaBank": "Romanalisoy\\PashaBank\\Facades\\PashaBank"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
